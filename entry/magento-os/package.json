{
    "name": "lightna-magento-frontend",
    "private": true,
    "devDependencies": {
        "deepmerge": "^4.3.1",
        "postcss-import": "^16.1.0",
        "prettier": "^3.3.3",
        "prettier-plugin-tailwindcss": "^0.6.5",
        "tailwindcss": "^3.4.3",
        "webpack": "^5.91.0",
        "webpack-cli": "^5.1.4"
    },
    "scripts": {
        "build-js": "webpack",
        "build-css": "npm run build-common-css -- --minify && npm run build-lane-css -- --minify && npm run build-product-css -- --minify && npm run build-listing-css -- --minify",
        "build-common-css": "npx tailwindcss -i ../../generated/magento-os/compiled/building/tailwind/common.css -o ../../generated/magento-os/compiled/asset.building/compiled/style/common.css",
        "build-product-css": "npx tailwindcss -i ../../generated/magento-os/compiled/building/tailwind/product-page.css -o ../../generated/magento-os/compiled/asset.building/compiled/style/product-page.css",
        "build-listing-css": "npx tailwindcss -i ../../generated/magento-os/compiled/building/tailwind/listing-page.css -o ../../generated/magento-os/compiled/asset.building/compiled/style/listing-page.css",
        "build-lane-css": "npx tailwindcss -i ../../generated/magento-os/compiled/building/tailwind/lane.css -o ../../generated/magento-os/compiled/asset.building/compiled/style/lane.css",
        "build": "webpack && npm run build-css && ./cli build.asset.sign",
        "watch-js": "webpack --mode=development",
        "watch-css": "npm run build-common-css -- --watch --verbose && npm run build-lane-css -- --watch --verbose"
    }
}
